ContextMenuItem Body=\"Delete\" variant=\"error\" />\n              </ContextMenuGroup>\n            </ContextMenuSubContent>\n          </ContextMenuSub>\n        </ContextMenuGroup>\n        <ContextMenuSeparator />\n        <ContextMenuGroup>\n          <ContextMenuCheckboxItem checked Body=\"Show Bookmarks\" />\n          <ContextMenuCheckboxItem Body=\"Show Full URLs\" />\n        </ContextMenuGroup>\n      </ContextMenuContent>\n    </ContextMenu>\n  );\n}\n",
