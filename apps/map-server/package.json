{
  "name": "@notion-kit/map-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "db:clean": "pnpm with-env tsx scripts/cleanup-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "pnpm with-env drizzle-kit push",
    "db:studio": "pnpm with-env drizzle-kit studio",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 pnpm with-env tsx watch src/index.ts",
    "format": "prettier --check . \"!**/*.{md,mdx}\" --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 pnpm with-env node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@notion-kit/prettier-config",
  "dependencies": {
    "@better-fetch/fetch": "catalog:",
    "@fastify/cors": "catalog:fastify",
    "@fastify/swagger": "catalog:fastify",
    "@fastify/websocket": "catalog:fastify",
    "@scalar/fastify-api-reference": "catalog:fastify",
    "@t3-oss/env-core": "catalog:env",
    "@vercel/postgres": "^0.10.0",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "catalog:fastify",
    "gtfs-realtime-bindings": "^1.1.1",
    "jszip": "^3.10.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:node",
    "dotenv-cli": "catalog:env",
    "drizzle-kit": "^0.31.9",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.19.3",
    "typescript": "catalog:"
  }
}
