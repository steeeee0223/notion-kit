{
  "name": "@notion-kit/e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "next dev -p 3001",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "pretest:e2e": "turbo run build --filter=@notion-kit/table-view",
    "pretest:e2e:coverage": "turbo run build --filter=@notion-kit/table-view",
    "start": "next start -p 3001",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_COVERAGE=1 playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@notion-kit/prettier-config",
  "dependencies": {
    "@notion-kit/auth": "workspace:*",
    "@notion-kit/auth-ui": "workspace:*",
    "@notion-kit/cn": "workspace:*",
    "@notion-kit/hooks": "workspace:*",
    "@notion-kit/i18n": "workspace:*",
    "@notion-kit/icons": "workspace:*",
    "@notion-kit/schemas": "workspace:*",
    "@notion-kit/settings-panel": "workspace:*",
    "@notion-kit/table-view": "workspace:*",
    "@notion-kit/ui": "workspace:*",
    "@notion-kit/utils": "workspace:*",
    "next": "catalog:next16",
    "react": "catalog:react19",
    "react-compiler-runtime": "catalog:react-compiler",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@ampproject/remapping": "catalog:test",
    "@jridgewell/trace-mapping": "catalog:test",
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "@playwright/test": "catalog:test",
    "@tailwindcss/postcss": "catalog:tailwind-v4",
    "@testing-library/react": "catalog:rtl",
    "@types/node": "catalog:node",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:test",
    "eslint": "catalog:",
    "jsdom": "catalog:rtl",
    "monocart-coverage-reports": "catalog:test",
    "prettier": "catalog:",
    "tailwindcss": "catalog:tailwind-v4",
    "typescript": "catalog:",
    "vitest": "catalog:test"
  }
}
