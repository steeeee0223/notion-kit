{
  "name": "@notion-kit/storybook",
  "version": "1.0.0-beta.0",
  "private": true,
  "type": "module",
  "scripts": {
    "addon": "storybook add",
    "build": "pnpm with-env storybook build",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "dev": "pnpm with-env storybook dev -p 6006",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpx http-server storybook-static",
    "test": "vitest --project=storybook --silent=passed-only --run",
    "typecheck": "tsc --noEmit",
    "upgrade": "pnpx storybook@latest upgrade",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@notion-kit/prettier-config",
  "dependencies": {
    "@dnd-kit/core": "catalog:ui",
    "@dnd-kit/modifiers": "catalog:ui",
    "@dnd-kit/sortable": "catalog:ui",
    "@notion-kit/auth-ui": "workspace:*",
    "@notion-kit/cn": "workspace:*",
    "@notion-kit/code-block": "workspace:*",
    "@notion-kit/hooks": "workspace:*",
    "@notion-kit/i18n": "workspace:*",
    "@notion-kit/icons": "workspace:*",
    "@notion-kit/registry": "workspace:*",
    "@notion-kit/schemas": "workspace:*",
    "@notion-kit/settings-panel": "workspace:*",
    "@notion-kit/table-view": "workspace:*",
    "@notion-kit/ui": "workspace:*",
    "@notion-kit/utils": "workspace:*",
    "@stripe/react-stripe-js": "catalog:stripe",
    "@stripe/stripe-js": "catalog:stripe",
    "lucide-react": "catalog:ui",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-hotkeys-hook": "catalog:ui",
    "uuid": "catalog:uuid"
  },
  "devDependencies": {
    "@notion-kit/config": "workspace:*",
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@t3-oss/env-core": "catalog:env",
    "@tailwindcss/postcss": "catalog:tailwind-v4",
    "@types/node": "catalog:node22",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitest/browser-playwright": "catalog:test",
    "@vitest/coverage-v8": "catalog:test",
    "dotenv-cli": "catalog:env",
    "eslint": "catalog:",
    "msw": "catalog:test",
    "msw-storybook-addon": "catalog:test",
    "playwright": "catalog:test",
    "prettier": "catalog:",
    "storybook": "^10.3.5",
    "storybook-react-rsbuild": "^3.2.3",
    "tailwindcss": "catalog:tailwind-v4",
    "typescript": "catalog:",
    "vitest": "catalog:test"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
