{
  "name": "@notion-kit/map",
  "version": "1.0.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/steeeee0223/notion-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/steeeee0223/notion-kit.git",
    "directory": "packages/map"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "license": "MIT",
  "scripts": {
    "build": "tsdown && pnpm build:css",
    "build:css": "tailwindcss -i ./src/style.css -o ./dist/style.css --minify",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@notion-kit/cn": "workspace:*",
    "@notion-kit/icons": "workspace:*",
    "@notion-kit/ui": "workspace:*",
    "lodash.isequal": "catalog:fns",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "@notion-kit/config": "workspace:*",
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tailwind-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "@testing-library/react": "catalog:rtl",
    "@types/lodash.isequal": "catalog:fns",
    "@vitejs/plugin-react": "catalog:test",
    "babel-plugin-react-compiler": "catalog:react-compiler",
    "eslint": "catalog:",
    "jsdom": "catalog:rtl",
    "prettier": "catalog:",
    "react-compiler-runtime": "catalog:react-compiler",
    "tailwindcss": "catalog:tailwind-v4",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "prettier": "@notion-kit/prettier-config"
}
