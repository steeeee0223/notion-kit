{
  "name": "@notion-kit/registry",
  "version": "0.16.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/steeeee0223/notion-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/steeeee0223/notion-kit.git",
    "directory": "packages/registry"
  },
  "exports": {
    "./*": {
      "default": "./src/*/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@notion-kit/cn": "workspace:*",
    "@notion-kit/hooks": "workspace:*",
    "@notion-kit/shadcn": "workspace:*"
  },
  "devDependencies": {
    "@notion-kit/config": "workspace:*",
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "babel-plugin-react-compiler": "catalog:react-compiler",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react-compiler-runtime": "catalog:react-compiler",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:react19",
    "zod": "catalog:"
  },
  "prettier": "@notion-kit/prettier-config",
  "babel": {
    "plugins": [
      "babel-plugin-react-compiler"
    ]
  }
}
