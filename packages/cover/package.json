{
  "name": "@notion-kit/cover",
  "version": "0.11.1-beta.8",
  "bugs": {
    "url": "https://github.com/steeeee0223/notion-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/steeeee0223/notion-kit.git",
    "directory": "packages/cover"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "scripts": {
    "build": "tsup --config=../../tooling/config/tsup.config.ts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup --config=../../tooling/config/tsup.config.ts --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@notion-kit/cn": "workspace:*",
    "@notion-kit/common": "workspace:*",
    "@notion-kit/shadcn": "workspace:*",
    "@notion-kit/single-image-dropzone": "workspace:*",
    "@notion-kit/spinner": "workspace:*",
    "@notion-kit/unsplash": "workspace:*",
    "lucide-react": "catalog:ui"
  },
  "devDependencies": {
    "@notion-kit/eslint-config": "workspace:*",
    "@notion-kit/prettier-config": "workspace:*",
    "@notion-kit/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "bundleDependencies": [
    "@notion-kit/common"
  ],
  "prettier": "@notion-kit/prettier-config"
}
